{
  "manifest_version": 3,
  "name": "YouTube Sentiment Insights",
  "version": "2.0",
  "description": "Analyzes YouTube video comments for sentiment — live while you watch.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost/*"
  ]
}